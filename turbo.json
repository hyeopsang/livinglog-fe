{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "NEXT_PUBLIC_GRAPHQL_HTTP_URL",
        "NEXT_PUBLIC_GRAPHQL_WS_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "NEXT_PUBLIC_GRAPHQL_HTTP_URL",
        "NEXT_PUBLIC_GRAPHQL_WS_URL"
      ]
    },
    "codegen": {
      "cache": false
    }
  }
}
